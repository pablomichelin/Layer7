# PostgreSQL
POSTGRES_DB=layer7_license
POSTGRES_USER=layer7
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Ed25519 private key (64 hex chars, gerada com generate-license.py keygen)
ED25519_PRIVATE_KEY=CHANGE_ME_64_hex_chars

# Node
NODE_ENV=production
PORT=3001

# Publicacao segura F2.1
# Por defeito o origin privado 8445 fica preso ao loopback do host.
# So alterar para um IP privado/LAN quando existir ACL/firewall dedicada
# permitindo apenas o reverse proxy de borda e/ou troubleshooting controlado.
LICENSE_SERVER_ORIGIN_BIND_IP=127.0.0.1
LICENSE_SERVER_ORIGIN_PORT=8445
