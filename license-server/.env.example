# PostgreSQL
POSTGRES_DB=layer7_license
POSTGRES_USER=layer7
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Ed25519 private key (64 hex chars, gerada com generate-license.py keygen)
# Pode ser fornecida por ED25519_PRIVATE_KEY ou ED25519_PRIVATE_KEY_FILE.
ED25519_PRIVATE_KEY=CHANGE_ME_64_hex_chars
# ED25519_PRIVATE_KEY_FILE=/run/secrets/layer7-ed25519.key

# Bootstrap administrativo one-shot/recovery only.
# Nao manter password bootstrap permanente no .env depois do uso.
ADMIN_BOOTSTRAP_EMAIL=admin@systemup.inf.br
ADMIN_BOOTSTRAP_NAME=Layer7_Admin
# ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_strong_admin_password
# ADMIN_BOOTSTRAP_PASSWORD_FILE=/run/secrets/layer7-admin-bootstrap.txt

# Node
NODE_ENV=production
PORT=3001

# Publicacao segura F2.1
# Por defeito o origin privado 8445 fica preso ao loopback do host.
# So alterar para um IP privado/LAN quando existir ACL/firewall dedicada
# permitindo apenas o reverse proxy de borda e/ou troubleshooting controlado.
LICENSE_SERVER_ORIGIN_BIND_IP=127.0.0.1
LICENSE_SERVER_ORIGIN_PORT=8445
