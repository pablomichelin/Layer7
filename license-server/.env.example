# PostgreSQL
POSTGRES_DB=layer7_license
POSTGRES_USER=layer7
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# JWT (string aleatoria 32+ chars)
JWT_SECRET=CHANGE_ME_random_string_here

# Ed25519 private key (64 hex chars, gerada com generate-license.py keygen)
ED25519_PRIVATE_KEY=CHANGE_ME_64_hex_chars

# Node
NODE_ENV=production
PORT=3001
