#!/bin/sh

set -eu

TABLE_BLOCK="layer7_block"
TABLE_TAGGED="layer7_tagged"
TABLE_BLOCK_DST="layer7_block_dst"
RULES_DIR="/usr/local/etc/layer7"
RULES_PATH="${RULES_DIR}/pf.conf"
RULES_SAMPLE="${RULES_DIR}/pf.conf.sample"
BL_CONFIG="/usr/local/etc/layer7/blacklists/config.json"

table_referenced() {
	_table="$1"
	/sbin/pfctl -sr 2>/dev/null | /usr/bin/grep -Eq "<${_table}[:>]"
}

table_ready() {
	_table="$1"
	if /sbin/pfctl -s Tables 2>/dev/null | /usr/bin/grep -qw "$_table"; then
		return 0
	fi
	if table_referenced "$_table"; then
		return 0
	fi
	return 1
}

ensure_table() {
	_table="$1"
	if table_ready "$_table"; then
		return 0
	fi
	/sbin/pfctl -t "$_table" -T add 127.0.0.254 2>/dev/null && \
		/sbin/pfctl -t "$_table" -T delete 127.0.0.254 2>/dev/null && \
		return 0
	echo "layer7-pfctl: failed to ensure table ${_table}" >&2
	return 1
}

tables_missing() {
	for _t in "${TABLE_BLOCK}" "${TABLE_TAGGED}" "${TABLE_BLOCK_DST}"; do
		if ! table_ready "$_t"; then
			return 0
		fi
	done
	return 1
}

required_tables_ok() {
	for _t in "${TABLE_BLOCK}" "${TABLE_TAGGED}" "${TABLE_BLOCK_DST}"; do
		if ! table_ready "$_t"; then
			echo "layer7-pfctl: missing required table ${_t}" >&2
			return 1
		fi
	done
	if [ -f "${BL_CONFIG}" ]; then
		_count=$(/usr/local/bin/php -r '
			$c = @json_decode(@file_get_contents("'"${BL_CONFIG}"'"), true);
			echo isset($c["rules"]) ? count($c["rules"]) : 0;
		' 2>/dev/null)
		_idx=0
		while [ "$_idx" -lt "${_count:-0}" ]; do
			_t="layer7_bld_${_idx}"
			if ! table_ready "$_t"; then
				echo "layer7-pfctl: missing blacklist table ${_t}" >&2
				return 1
			fi
			_idx=$((_idx + 1))
		done
	fi
	return 0
}

force_reload_rules_debug() {
	if [ -f /tmp/rules.debug ]; then
		/sbin/pfctl -f /tmp/rules.debug 2>/dev/null || \
			echo "layer7-pfctl: failed to reload /tmp/rules.debug" >&2
	else
		echo "layer7-pfctl: /tmp/rules.debug not found for fallback reload" >&2
	fi
}

ensure_blacklist_tables() {
	_rc=0
	if [ ! -f "${BL_CONFIG}" ]; then
		return 0
	fi
	_count=$(/usr/local/bin/php -r '
		$c = @json_decode(@file_get_contents("'"${BL_CONFIG}"'"), true);
		echo isset($c["rules"]) ? count($c["rules"]) : 0;
	' 2>/dev/null)
	_idx=0
	while [ "$_idx" -lt "${_count:-0}" ]; do
		ensure_table "layer7_bld_${_idx}" || _rc=1
		_idx=$((_idx + 1))
	done
	return "$_rc"
}

write_rules() {
	/bin/mkdir -p "${RULES_DIR}"
	cat <<EOF > "${RULES_PATH}"
# Layer7 PF snippet (package-managed)
table <${TABLE_BLOCK}> persist
table <${TABLE_TAGGED}> persist
table <${TABLE_BLOCK_DST}> persist

# Anti-bypass: bloquear DoT (TCP 853) e DoQ (UDP 853) apenas para destinos externos.
block drop quick inet proto tcp to !<localsubnets> port 853 label "layer7:anti-dot"
block drop quick inet6 proto tcp to !<localsubnets> port 853 label "layer7:anti-dot6"
block drop quick inet proto udp to !<localsubnets> port 853 label "layer7:anti-doq"
block drop quick inet6 proto udp to !<localsubnets> port 853 label "layer7:anti-doq6"

# Bloqueio por origem do cliente (quarentena/tag) — apenas destinos externos.
block drop quick inet from <${TABLE_BLOCK}> to !<localsubnets> label "layer7:block:src"
block drop quick inet6 from <${TABLE_BLOCK}> to !<localsubnets> label "layer7:block:src6"

# Bloqueio por destino (sites/apps bloqueados).
block drop quick inet to <${TABLE_BLOCK_DST}> label "layer7:block:dst"
block drop quick inet6 to <${TABLE_BLOCK_DST}> label "layer7:block:dst6"

# layer7_tagged permanece disponivel para regras manuais/encadeadas.
EOF

	if [ ! -f "${RULES_SAMPLE}" ]; then
		cp "${RULES_PATH}" "${RULES_SAMPLE}"
	fi
}

	# Nota: as regras rdr para DNS forcado (force_dns) sao injectadas
	# directamente por layer7_inject_nat_to_anchor() em layer7.inc, porque
	# pfSense CE nao processa nat_rules_needed para packages.

flush_tables() {
	/sbin/pfctl -t "${TABLE_BLOCK}" -T flush >/dev/null 2>&1 || true
	/sbin/pfctl -t "${TABLE_TAGGED}" -T flush >/dev/null 2>&1 || true
	/sbin/pfctl -t "${TABLE_BLOCK_DST}" -T flush >/dev/null 2>&1 || true
}

# Tabelas layer7_bld_* (blacklist por IP) e excepcoes — necessario para remocao
# limpa e para evitar bloqueio residual apos pkg delete.
flush_tables_blacklist() {
	_i=0
	while [ "${_i}" -lt 32 ]; do
		/sbin/pfctl -t "layer7_bld_${_i}" -T flush >/dev/null 2>&1 || true
		_i=$((_i + 1))
	done
	/sbin/pfctl -t layer7_bl_except -T flush >/dev/null 2>&1 || true
}

flush_tables_all() {
	flush_tables
	flush_tables_blacklist
}

show_status() {
	echo "helper=/usr/local/libexec/layer7-pfctl"
	echo "rules=${RULES_PATH}"
	/sbin/pfctl -s Tables 2>/dev/null | grep "layer7_" || true
}

cmd="${1:-ensure}"
case "${cmd}" in
ensure)
		write_rules
		_rc=0
		ensure_table "${TABLE_BLOCK}" || _rc=1
		ensure_table "${TABLE_TAGGED}" || _rc=1
		ensure_table "${TABLE_BLOCK_DST}" || _rc=1
		ensure_blacklist_tables || _rc=1
		if tables_missing; then
			echo "layer7-pfctl: required tables missing, trying rules.debug reload" >&2
			force_reload_rules_debug
		fi
		if ! required_tables_ok; then
			exit 1
		fi
		if [ "$_rc" -ne 0 ]; then
			echo "layer7-pfctl: recovered after ensure warnings" >&2
		fi
		;;
flush)
		flush_tables
		;;
flush-all)
		flush_tables_all
		;;
show)
		show_status
		;;
*)
		echo "usage: $0 [ensure|flush|flush-all|show]" >&2
		exit 1
		;;
esac
