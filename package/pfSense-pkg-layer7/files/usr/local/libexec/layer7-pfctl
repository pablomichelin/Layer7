#!/bin/sh

set -eu

TABLE_BLOCK="layer7_block"
TABLE_TAGGED="layer7_tagged"
TABLE_BLOCK_DST="layer7_block_dst"
RULES_DIR="/usr/local/etc/layer7"
RULES_PATH="${RULES_DIR}/pf.conf"
RULES_SAMPLE="${RULES_DIR}/pf.conf.sample"
BL_CONFIG="/usr/local/etc/layer7/blacklists/config.json"

ensure_table() {
	_table="$1"
	if pfctl -s Tables 2>/dev/null | grep -qw "$_table"; then
		return 0
	fi
	pfctl -t "$_table" -T add 127.0.0.254 2>/dev/null && \
		pfctl -t "$_table" -T delete 127.0.0.254 2>/dev/null && \
		return 0
	return 1
}

tables_missing() {
	for _t in "${TABLE_BLOCK}" "${TABLE_BLOCK_DST}"; do
		if ! pfctl -s Tables 2>/dev/null | grep -qw "$_t"; then
			return 0
		fi
	done
	return 1
}

force_reload_rules_debug() {
	if [ -f /tmp/rules.debug ]; then
		/sbin/pfctl -f /tmp/rules.debug 2>/dev/null || true
	fi
}

ensure_blacklist_tables() {
	if [ ! -f "${BL_CONFIG}" ]; then
		return 0
	fi
	_count=$(/usr/local/bin/php -r '
		$c = @json_decode(@file_get_contents("'"${BL_CONFIG}"'"), true);
		echo isset($c["rules"]) ? count($c["rules"]) : 0;
	' 2>/dev/null)
	_idx=0
	while [ "$_idx" -lt "${_count:-0}" ]; do
		ensure_table "layer7_bld_${_idx}"
		_idx=$((_idx + 1))
	done
}

write_rules() {
	/bin/mkdir -p "${RULES_DIR}"
	cat > "${RULES_PATH}" <<EOF
# Layer7 PF snippet (package-managed)
table <${TABLE_BLOCK}> persist
table <${TABLE_TAGGED}> persist
table <${TABLE_BLOCK_DST}> persist

# Anti-bypass: bloquear DoT (TCP 853) e DoQ (UDP 853).
block drop quick inet proto tcp to port 853 label "layer7:anti-dot"
block drop quick inet6 proto tcp to port 853 label "layer7:anti-dot6"
block drop quick inet proto udp to port 853 label "layer7:anti-doq"
block drop quick inet6 proto udp to port 853 label "layer7:anti-doq6"

# Bloqueio por origem do cliente (quarentena/tag).
block drop quick inet from <${TABLE_BLOCK}> to any label "layer7:block:src"
block drop quick inet6 from <${TABLE_BLOCK}> to any label "layer7:block:src6"

# Bloqueio por destino (sites/apps bloqueados).
block drop quick inet to <${TABLE_BLOCK_DST}> label "layer7:block:dst"
block drop quick inet6 to <${TABLE_BLOCK_DST}> label "layer7:block:dst6"

# layer7_tagged permanece disponivel para regras manuais/encadeadas.
EOF
	if [ ! -f "${RULES_SAMPLE}" ]; then
		cp "${RULES_PATH}" "${RULES_SAMPLE}"
	fi
}

flush_tables() {
	pfctl -t "${TABLE_BLOCK}" -T flush >/dev/null 2>&1 || true
	pfctl -t "${TABLE_TAGGED}" -T flush >/dev/null 2>&1 || true
	pfctl -t "${TABLE_BLOCK_DST}" -T flush >/dev/null 2>&1 || true
}

show_status() {
	echo "helper=/usr/local/libexec/layer7-pfctl"
	echo "rules=${RULES_PATH}"
	pfctl -s Tables 2>/dev/null | grep "layer7_" || true
}

cmd="${1:-ensure}"
case "${cmd}" in
ensure)
		write_rules
		ensure_table "${TABLE_BLOCK}" || true
		ensure_table "${TABLE_TAGGED}" || true
		ensure_table "${TABLE_BLOCK_DST}" || true
		ensure_blacklist_tables
		if tables_missing; then
			force_reload_rules_debug
		fi
		;;
flush)
		flush_tables
		;;
show)
		show_status
		;;
*)
		echo "usage: $0 [ensure|flush|show]" >&2
		exit 1
		;;
esac
